//amra jodi event ar default behaviour remove korte chai tobe (preventDefault()) ata use korte hobe

<a href="https://tapasadhikari.com" id="websiteLink" target="_blank">Go to Website</a>
document.getElementById("websiteLink").addEventListener("click", function(e){
    e.preventDefault();
    console.log("Navigating to Website");
})

//amra jodi kono form ar default event stop korte chai 
<form action="" id="loginForm">
    <input type="text" placeholder="Username" required>
    <input type="password" placeholder="Password" required>
    <button type="submit">Login</button>
</form>
document.getElementById("loginForm").addEventListener("submit", function(e){
    e.preventDefault();
    console.log("Form submission prevented!");
})
